{
  "cli": {
    "version": ">= 3.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "test-apk": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "image": "latest",
        "simulator": true
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_CONFIG_API_URL": "$EXPO_PUBLIC_CONFIG_API_URL",
        "EXPO_PUBLIC_COUPONS_API_URL": "$EXPO_PUBLIC_COUPONS_API_URL",
        "EXPO_PUBLIC_REFERRAL_API_URL": "$EXPO_PUBLIC_REFERRAL_API_URL",
        "EXPO_PUBLIC_STRIPE_API_URL": "$EXPO_PUBLIC_STRIPE_API_URL",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "ios": {
        "credentialsSource": "remote",
        "enterpriseProvisioning": "universal",
        "distribution": "app-store"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "$APPLE_TEAM_ID",
        "appleId": "$APPLE_ID",
        "appleIdPassword": "$APPLE_ID_PASSWORD",
        "appleAppSpecificPassword": "$APPLE_APP_SPECIFIC_PASSWORD"
      }
    }
  }
}
